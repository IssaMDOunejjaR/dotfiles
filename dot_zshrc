# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

export EDITOR=nvim
export MANPAGER='nvim +Man!'

# --- PATH Setup ---
# Organized logically: Local bins -> Language Bins -> System Path
export PATH="$HOME/.local/bin:$HOME/Applications:$HOME/.spicetify:$HOME/.opencode/bin:$PATH"
export PATH="$HOME/.config/tmux/plugins/tmuxifier/bin:$PATH"
export PATH="$HOME/go/bin:$PATH"

# Bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# Bob (Neovim version manager)
export PATH="$HOME/.local/share/bob/nvim-bin:$PATH"

# RVM
export PATH="$PATH:$HOME/.rvm/bin"

# Pyenv (Note: If you use 'mise' for Python, you can delete this block)
export PYENV_ROOT="$HOME/.pyenv"
[[ -d $PYENV_ROOT/bin ]] && export PATH="$PYENV_ROOT/bin:$PATH"

# --- Zinit Setup ---
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"

if [ ! -d "$ZINIT_HOME" ]; then
  mkdir -p "$(dirname $ZINIT_HOME)"
  git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
fi

source "${ZINIT_HOME}/zinit.zsh"

# Powerlevel10k must be loaded synchronously for instant prompt to work
zinit ice depth=1; zinit light romkatv/powerlevel10k

# Turbo Mode: Load these plugins in the background
zinit wait'0a' lucid light-mode for \
  atinit"zicompinit; zicdreplay" \
    zsh-users/zsh-completions \
  atload"_zsh_autosuggest_start" \
    zsh-users/zsh-autosuggestions \
  aloxaf/fzf-tab

# CRITICAL: zsh-syntax-highlighting MUST be loaded synchronously (no turbo mode)
# and MUST be the last plugin loaded to prevent ZLE race conditions.
zinit light zsh-users/zsh-syntax-highlighting

zinit snippet OMZP::colored-man-pages
# --- Completions ---
# Clean broken symlinks in Zinit's completion directory to prevent compinit errors
find "${ZINIT_HOME:-$HOME/.local/share/zinit}/completions" -xtype l -delete 2>/dev/null

autoload -U compinit && compinit

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# --- Keybindings ---
bindkey -e
bindkey '^p' history-search-backward
bindkey '^n' history-search-forward

# --- History ---
HISTSIZE=10000
HISTFILE=~/.zsh_history
setopt appendhistory
setopt sharehistory
setopt hist_ignore_space
setopt hist_ignore_all_dups
setopt hist_save_no_dups
setopt hist_ignore_dups
setopt hist_find_no_dups
setopt HIST_REDUCE_BLANKS    # Clean up extra blank spaces in history
setopt EXTENDED_HISTORY      # Save timestamps in history

# --- Completion Styling ---
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' menu no
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls --color $realpath'
zstyle ':fzf-tab:complete:__zoxide_z:*' fzf-preview 'ls --color $realpath'
zstyle ':completion:*' rehash true
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path ~/.zsh/cache

# --- Aliases ---
alias ls='ls --color'
alias grep='grep --color=auto' # Changed from always to auto to prevent piping issues
alias v='nvim'
alias la='ls -la'
alias ll='ls -l'
alias c='clear'
alias kubectl='kubecolor'
alias kc='kubectl'
alias lgit='lazygit'
alias ldc='lazydocker'

# Optional: Modern CLI tool aliases (uncomment if you install eza/bat)
# alias ls='eza --icons --group-directories-first'
# alias la='eza -la --icons --group-directories-first'
# alias ll='eza -l --icons --group-directories-first'
# alias cat='bat --paging=never'

# --- Tool Initialization ---
# Note: 'mise' can replace pyenv, fnm, and rbenv. If you use mise for everything,
# you can delete the pyenv and fnm blocks entirely.

if command -v pyenv &>/dev/null; then
  eval "$(pyenv init - zsh)"
fi

if command -v fzf &>/dev/null; then
  eval "$(fzf --zsh)"
fi

if command -v zoxide &>/dev/null; then
  eval "$(zoxide init --cmd cd zsh)"
fi

if command -v fnm &>/dev/null; then
  eval "$(fnm env --use-on-cd --shell zsh)"
fi

if test -f /home/linuxbrew/.linuxbrew/bin/brew; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

if command -v mise &>/dev/null; then
  eval "$(mise activate zsh)" # Added 'zsh' for proper mise activation
fi

# --- Completion Caching ---
# Caching completions is MUCH faster than running the command on every shell start
if command -v ng &>/dev/null; then
  ng_cache="${XDG_CACHE_HOME:-$HOME/.cache}/ng_completion_zsh"
  if [[ ! -f "$ng_cache" || "$HOME/.nvm/versions/$(node -v)/bin/ng" -nt "$ng_cache" ]]; then
    ng completion script >! "$ng_cache" 2>/dev/null
  fi
  source "$ng_cache"
fi

if command -v kubecolor &>/dev/null && command -v kubectl &>/dev/null; then
  kubectl_cache="${XDG_CACHE_HOME:-$HOME/.cache}/kubectl_completion_zsh"
  if [[ ! -f "$kubectl_cache" || "$(which kubectl)" -nt "$kubectl_cache" ]]; then
    kubectl completion zsh >! "$kubectl_cache" 2>/dev/null
  fi
  source "$kubectl_cache"
  compdef kubecolor=kubectl
fi

#THIS MUST BE AT THE END OF THE FILE FOR SDKMAN TO WORK!!!
export SDKMAN_DIR="$HOME/.sdkman"
if [[ -s "$HOME/.sdkman/bin/sdkman-init.sh" ]]; then
  source "$HOME/.sdkman/bin/sdkman-init.sh"
fi
